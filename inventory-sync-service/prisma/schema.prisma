generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductReadModel {
  id          String   @id
  name        String
  sku         String   @unique
  description String?
  createdAt   DateTime
}

model StockReadModel {
  id          String   @id @default(uuid())
  productId   String
  productName String
  sku         String
  branch      String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([productId, branch])
}

model MovementReadModel {
  id           String   @id @default(uuid())
  productId    String
  productName  String
  sku          String
  type         String
  branch       String?
  sourceBranch String?
  targetBranch String?
  quantity     Int
  createdAt    DateTime
}

model ProcessedEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType   String
  payload     Json
  processedAt DateTime @default(now())
}
